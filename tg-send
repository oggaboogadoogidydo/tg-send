#!/usr/bin/env bash
# tg-send – send messages/files to a Telegram bot
set -euo pipefail

# ---------- Configuration file loading ----------
# System-wide config
if [[ -f /etc/tg-send.conf ]]; then
    source /etc/tg-send.conf
fi

# User config (XDG compliant)
if [[ -n "${XDG_CONFIG_HOME:-}" ]]; then
    user_config="$XDG_CONFIG_HOME/tg-send/config"
elif [[ -n "${HOME:-}" ]]; then
    user_config="$HOME/.config/tg-send/config"
else
    user_config=""
fi
if [[ -n "$user_config" && -f "$user_config" ]]; then
    source "$user_config"
fi

# ---------- Defaults ----------
TOKEN="${TG_TOKEN:-${TOKEN:-}}"
CHAT_ID="${TG_CHAT_ID:-${CHAT_ID:-}}"
MESSAGE=""
FILE=""
PARSE_MODE="${PARSE_MODE:-}"

usage() {
    cat <<EOF
Usage: tg-send [options] [message...]

Options:
  -t TOKEN      Bot token (overrides \$TG_TOKEN and config file)
  -c CHAT_ID    Chat ID (overrides \$TG_CHAT_ID and config file)
  -m MESSAGE    Send this text message (if not given, the first non-option
                argument(s) become the message, or stdin is read)
  -f FILE       Send this file (as a document)
  -p MODE       Parse mode for text (HTML, Markdown, MarkdownV2)
  -h, --help    Show this help
  --            Stop parsing options; everything after is the message

If no -m and no message argument(s), reads from stdin (unless stdin is a terminal).
If -f is given, any text (from -m, arguments, or stdin) is used as the caption.
EOF
    exit 0
}

# ---------- Parse command-line arguments ----------
args=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -t) TOKEN="$2"; shift 2 ;;
        -c) CHAT_ID="$2"; shift 2 ;;
        -m) MESSAGE="$2"; shift 2 ;;
        -f) FILE="$2"; shift 2 ;;
        -p) PARSE_MODE="$2"; shift 2 ;;
        -h|--help) usage ;;
        --) shift; args+=("$@"); break ;;
        -*)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
        *)
            args+=("$1"); shift
            ;;
    esac
done

# If message not set via -m, build from remaining arguments
if [[ -z "$MESSAGE" && ${#args[@]} -gt 0 ]]; then
    # Join arguments with space
    MESSAGE=$(printf "%s " "${args[@]}" | sed 's/ $//')
fi

# Validate token and chat ID
if [[ -z "$TOKEN" || -z "$CHAT_ID" ]]; then
    echo "Error: Bot token and chat ID must be set via environment, config file, or -t/-c" >&2
    exit 1
fi

# If no message set and no file, try reading stdin (if not a terminal)
if [[ -z "$MESSAGE" && -z "$FILE" ]] && [[ ! -t 0 ]]; then
    # Read whole stdin (preserve trailing newlines if any)
    MESSAGE=$(cat)
fi

# If still no message but we have a file, and stdin is not a terminal, use stdin as caption
if [[ -z "$MESSAGE" && -n "$FILE" ]] && [[ ! -t 0 ]]; then
    MESSAGE=$(cat)
fi

# If neither message nor file, show usage
if [[ -z "$MESSAGE" && -z "$FILE" ]]; then
    echo "Error: Nothing to send" >&2
    usage
fi

# ---------- Build and send ----------
API_URL="https://api.telegram.org/bot${TOKEN}"

if [[ -n "$FILE" ]]; then
    if [[ ! -f "$FILE" ]]; then
        echo "Error: File not found: $FILE" >&2
        exit 1
    fi
    # Send file as document
    curl -s -X POST "${API_URL}/sendDocument" \
        -F "chat_id=${CHAT_ID}" \
        -F "document=@${FILE}" \
        -F "caption=${MESSAGE}" \
        ${PARSE_MODE:+-F "parse_mode=${PARSE_MODE}"} \
        | jq -e '.ok' >/dev/null
else
    # Send text message (escape JSON)
    ESCAPED=$(printf '%s' "$MESSAGE" | jq -sRr @json)
    curl -s -X POST "${API_URL}/sendMessage" \
        -d "chat_id=${CHAT_ID}" \
        -d "text=${ESCAPED}" \
        ${PARSE_MODE:+-d "parse_mode=${PARSE_MODE}"} \
        | jq -e '.ok' >/dev/null
fi

if [[ $? -ne 0 ]]; then
    echo "Error: Telegram API request failed" >&2
    exit 1
fi
